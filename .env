CLOUD_TELEMETRY_APP_NAME=Cloud Telemetry Backend
CLOUD_TELEMETRY_HOST=0.0.0.0
CLOUD_TELEMETRY_PORT=8765
CLOUD_TELEMETRY_INGEST_PREFIX=/_cloud_telemetry

# 后台 X-API-Key 列表，多个 key 用逗号分隔
CLOUD_TELEMETRY_ADMIN_API_KEYS=change-me

# Docker 部署默认使用 PostgreSQL；本地开发可改为 sqlite
CLOUD_TELEMETRY_DATABASE_TYPE=sqlite
CLOUD_TELEMETRY_POSTGRESQL_HOST=postgres
CLOUD_TELEMETRY_POSTGRESQL_PORT=5432
CLOUD_TELEMETRY_POSTGRESQL_DATABASE=mofox_cloud_telemetry
CLOUD_TELEMETRY_POSTGRESQL_USER=postgres
CLOUD_TELEMETRY_POSTGRESQL_PASSWORD=postgres
CLOUD_TELEMETRY_POSTGRESQL_SCHEMA=cloud_telemetry

# 本地开发可使用 SQLite
# CLOUD_TELEMETRY_DATABASE_TYPE=sqlite
# CLOUD_TELEMETRY_SQLITE_PATH=data/cloud_telemetry/cloud_telemetry.db

# 心跳调度参数
CLOUD_TELEMETRY_DEFAULT_HEARTBEAT_INTERVAL_SECONDS=300
CLOUD_TELEMETRY_CHALLENGE_TTL_SECONDS=300
CLOUD_TELEMETRY_INSTALL_CREDENTIAL_TTL_SECONDS=2592000
CLOUD_TELEMETRY_OFFLINE_GRACE_FACTOR=2.0
CLOUD_TELEMETRY_OFFLINE_SCAN_INTERVAL_SECONDS=30.0

# Abuse protection
CLOUD_TELEMETRY_MAX_REQUEST_BODY_BYTES=262144
CLOUD_TELEMETRY_RATE_LIMIT_WINDOW_SECONDS=60
CLOUD_TELEMETRY_IP_RATE_LIMIT_PER_WINDOW=120
CLOUD_TELEMETRY_CREDENTIAL_RATE_LIMIT_PER_WINDOW=120
CLOUD_TELEMETRY_REGISTRATION_FAILURE_LIMIT=5
CLOUD_TELEMETRY_REGISTRATION_FAILURE_COOLDOWN_SECONDS=300

# 心跳缺口补齐窗口（窗口数）
CLOUD_TELEMETRY_GAP_RECOVERY_WINDOW=50

# 单实例详情接口最近 N 条心跳与诊断事件上限
CLOUD_TELEMETRY_INSTANCE_DETAIL_MAX_WINDOWS=50
CLOUD_TELEMETRY_INSTANCE_DETAIL_MAX_DIAGNOSTIC_EVENTS=50

# MaxMind GeoLite2-City.mmdb 路径，留空表示不启用地域派生
CLOUD_TELEMETRY_GEOIP_DATABASE_PATH=

# 数据库连接参数
CLOUD_TELEMETRY_CONNECTION_POOL_SIZE=10
CLOUD_TELEMETRY_CONNECTION_TIMEOUT=30
CLOUD_TELEMETRY_SQL_ECHO=false
